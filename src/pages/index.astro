---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = (await getCollection('blog', (p) => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = allPosts.slice(0, 6);

// Top 10 tags by frequency
const tagCounts: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const topTags = Object.entries(tagCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 10);

function readTime(): number {
  return 5;
}
---

<BaseLayout
  title="Digital Factory"
  description="Practical guides, prompt packs, and digital tools for creators, freelancers, and side-hustlers. New resources every day."
  type="website"
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-surface to-white dark:from-gray-900 dark:to-gray-950 border-b border-gray-200 dark:border-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-20 text-center">
      <p class="inline-block text-xs font-semibold uppercase tracking-widest text-accent mb-4 bg-accent/10 px-3 py-1 rounded-full">
        New posts every day
      </p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-primary dark:text-white leading-tight mb-5">
        Tools &amp; guides for the<br />
        <span class="text-accent">digital creator economy</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl mx-auto mb-8">
        Prompt packs, productivity templates, and step-by-step guides. Instantly downloadable on Gumroad.
      </p>
      <a
        href="/blog"
        class="inline-flex items-center gap-2 bg-primary dark:bg-white text-white dark:text-primary font-semibold px-7 py-3 rounded-xl hover:opacity-90 transition-opacity shadow-sm"
      >
        Browse all articles
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Latest posts -->
  {latestPosts.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-primary dark:text-white">Latest articles</h2>
        <a href="/blog" class="text-sm text-accent hover:underline">View all →</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
            tags={post.data.tags}
            readTime={readTime()}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Popular tags -->
  {topTags.length > 0 && (
    <section class="border-t border-gray-200 dark:border-gray-800">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
        <h2 class="text-2xl font-bold text-primary dark:text-white mb-8">Browse by topic</h2>
        <div class="flex flex-wrap gap-3">
          {topTags.map(([tag, count]) => (
            <a
              href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
              class="flex items-center gap-2 bg-surface dark:bg-gray-900 border border-gray-200 dark:border-gray-800 px-4 py-2 rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:border-accent/50 hover:text-accent transition-colors"
            >
              {tag}
              <span class="text-xs text-gray-400">{count}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Empty state -->
  {allPosts.length === 0 && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-24 text-center">
      <p class="text-gray-400 dark:text-gray-600 text-lg">First post coming soon…</p>
    </section>
  )}
</BaseLayout>
