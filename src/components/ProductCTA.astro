---
interface Props {
  productUrl?: string;
  title?: string;
}

const { productUrl, title = 'the full resource pack' } = Astro.props;

if (!productUrl) return;
---

<aside class="my-10 rounded-2xl border-2 border-accent/30 bg-gradient-to-br from-surface to-white dark:from-gray-900 dark:to-gray-800 p-6 sm:p-8 shadow-sm">
  <div class="flex items-start gap-4">
    <span class="text-3xl" aria-hidden="true">🎯</span>
    <div class="flex-1 min-w-0">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-1">Get the full resource</p>
      <h3 class="text-lg font-bold text-primary dark:text-white leading-snug mb-2">{title}</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-5">
        Save hours — everything you need in one download. Instantly available on Gumroad.
      </p>
      <a
        href={productUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors shadow-sm"
      >
        Get it on Gumroad
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>
</aside>
