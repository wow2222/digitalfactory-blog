---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 dark:border-gray-800 mt-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
      <div>
        <p class="font-bold text-primary dark:text-white mb-2">⚡ Digital Factory</p>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Practical guides, prompt packs, and digital tools for the modern creator.
        </p>
      </div>
      <div>
        <p class="font-semibold text-sm text-gray-700 dark:text-gray-300 mb-3">Quick links</p>
        <ul class="space-y-2 text-sm text-gray-500 dark:text-gray-400">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li><a href="/blog" class="hover:text-accent transition-colors">Blog</a></li>
          <li><a href="/about" class="hover:text-accent transition-colors">About</a></li>
        </ul>
      </div>
      <div>
        <p class="font-semibold text-sm text-gray-700 dark:text-gray-300 mb-3">Subscribe</p>
        <ul class="space-y-2 text-sm text-gray-500 dark:text-gray-400">
          <li>
            <a href="/rss.xml" class="hover:text-accent transition-colors flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
              </svg>
              RSS Feed
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-200 dark:border-gray-800 pt-6 text-center text-xs text-gray-400 dark:text-gray-600">
      &copy; {year} Digital Factory. All rights reserved.
    </div>
  </div>
</footer>
